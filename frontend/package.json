{
  "name": "ananke-frontend",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "format": "prettier -w .",
    "lint": "prettier --check . && eslint . && tsc -b",
    "preview": "vite preview",
    "gen-types": "cargo run --quiet --manifest-path ../Cargo.toml --example dump-openapi | openapi-typescript /dev/stdin -o src/api/types.ts && prettier --write src/api/types.ts"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.4",
    "@codemirror/language": "^6.11.0",
    "@codemirror/legacy-modes": "^6.5.3",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.36.4",
    "@fontsource-variable/ibm-plex-sans": "^5.2.8",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@tailwindcss/vite": "4.2.2",
    "@tanstack/react-query": "^5.99.2",
    "dompurify": "^3.2.5",
    "highlight.js": "^11.11.1",
    "i18next": "^25.1.3",
    "i18next-browser-languagedetector": "^8.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^15.5.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.6.1",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "tailwindcss": "4.2.2",
    "uplot": "^1.6.32",
    "uplot-react": "^1.2.4"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@eslint/js": "^9.39.4",
    "@rolldown/plugin-babel": "^0.2.2",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.8.3",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4"
  },
  "overrides": {
    "typescript": "$typescript"
  }
}
